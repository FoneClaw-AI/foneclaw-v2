# === GEO 公开仓库 .gitignore ===

# 生成的 HTML（由 build_multi.py 产出，不入 git）
*.html

# 构建缓存
_build_cache.pkl
__pycache__/
*.pyc

# 备份文件
*.bak*
batch_backups/

# 发布包目录
foneclaw-deploy/

# 临时文件
__qa_*.html
tmp_*.py
tmp_*.json
tmp_*.out

# QA 报告和脚本（临时产物）
*_strict_qa.py
*_strict_qa_report.json
*_codex_*_qa*.py
*_codex_*_qa*.json
*_mechanical_qa.py
*_qa_check.py
*_manual_*.json
*_manual_*.out
de_strict_qa_report.json
ar_codex_strict_qa_report.json
ar_codex_deep_qa2.json

# 临时修复脚本
fix_*.py
make_*.py
tmp_*.py

# 文章批处理数据（大量 JSON，不影响 GEO）
batch*_data.json
article_keywords_data.py
*_batch_*.py
*_article_rewrites.py
*_merge_articles.py
*_extra_sections.py

# 图片压缩和处理脚本
compress_images.py
image_manifest.json

# SEO/分析工具
seo_writing_spec.md
*_analysis*.py
*_report*.py
*_check*.py

# OS
.DS_Store
Thumbs.db

# 编辑器
.vscode/
.idea/
*.swp
*.swo

# 上传临时目录
upload_*/

# 原始素材
*_raw.txt
*_raw.py

# 系统监控脚本（非产品内容）
*.sh
!scripts/*.sh

# === P0: 内部目录（GEO 无价值，不公开） ===
archive/
bak_*/
gemini_outputs/
prompts/
keyword/
twitter/
scripts/

# === 内部文档（构建/部署/项目管理，非产品内容） ===
CATEGORY_RULES.md
PROJECT_SUMMARY.md
TRAFFIC_GROWTH_PLAN.md
ARTICLE_INDEX.md.deprecated
ARTICLE_TODO.md
DEPLOY.md
KEYWORD_ANALYSIS.md
LAUNCH_CHECKLIST.md
SEO_CHECKLIST.md
WEBSITE_RULES.md

# === 内部构建脚本（根目录 .py 文件） ===
